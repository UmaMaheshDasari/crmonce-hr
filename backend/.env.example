# ─────────────────────────────────────────────────────────────
#  HR System — Backend Environment Variables
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# ── Azure AD (for D365 auth) ──────────────────────────────────
# Get these from portal.azure.com → App registrations
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret

# ── Dynamics 365 ─────────────────────────────────────────────
# Your D365 org URL (no trailing slash)
D365_BASE_URL=https://yourorg.crm.dynamics.com
D365_API_VERSION=9.2

# ── JWT ──────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── PostgreSQL (local audit/log DB) ──────────────────────────
# Install PostgreSQL locally or comment these out if not using
PG_HOST=localhost
PG_PORT=5432
PG_DB=hr_system
PG_USER=postgres
PG_PASSWORD=postgres

# ── Redis (session/cache) ─────────────────────────────────────
# Install Redis locally or comment these out if not using
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── eTime Office ─────────────────────────────────────────────
# Your eTime Office server URL and API key
ETIME_BASE_URL=http://your-etime-server:8080
ETIME_API_KEY=your-etime-api-key
# Cron schedule — every 15 minutes
ETIME_SYNC_INTERVAL=*/15 * * * *

# ── Email (Nodemailer) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=HR System <hr@yourcompany.com>

# ── Frontend URL (CORS) ───────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── File Uploads ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
